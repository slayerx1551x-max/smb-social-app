# Root env example. Real secrets live in per-package .env files (gitignored)
# and in Supabase project secrets — never commit real keys.
#
# app/.env (Expo public client config):
#   EXPO_PUBLIC_SUPABASE_URL=
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=
#
# Supabase Edge Function secrets (set via dashboard or `supabase secrets set`):
#   ANTHROPIC_API_KEY=            # Phase 4 (caption generation via Claude)
#   STT_OPENAI_API_KEY=          # Phase 5 (video transcription via Whisper)
#   META_APP_ID / META_APP_SECRET # Phase 2 (Instagram + Facebook OAuth)
#   TIKTOK_CLIENT_KEY / TIKTOK_CLIENT_SECRET
#   YOUTUBE_CLIENT_ID / YOUTUBE_CLIENT_SECRET
#   STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET
