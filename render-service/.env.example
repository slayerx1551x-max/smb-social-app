# Render service env. The service uses the SERVICE ROLE key to upload rendered
# MP4s to Supabase Storage — keep it secret, server-side only.
SUPABASE_URL=https://tqvznoeszjuouvzsovhk.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key   # used to verify the caller's JWT
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # server-only; never ship to the app
PORT=8787
