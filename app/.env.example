# Expo public env vars (safe to expose in the client bundle).
# Copy to `.env` and fill from Supabase → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Optional — URL of the Remotion render service (Phase 7). When set, the
# Animation studio renders real MP4s. Leave unset for in-app preview only.
# EXPO_PUBLIC_RENDER_URL=http://localhost:8787
